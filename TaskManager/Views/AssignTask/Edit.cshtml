@using Tasklyne.Models
@model AssignTask

@{
    ViewData["Title"] = "Edit Assign Task";
}
@Html.ValidationSummary()
<h1>Edit Assign Task</h1>

<form asp-action="Edit" asp-controller="AssignTask">
    <input type="hidden" asp-for="Id" />
    <div class="form-group">
        <label>Employee</label>
        <select asp-for="Employees" name="Employees" class="form-control" multiple>
            <option value="">Select Employee</option>
            @foreach (var employee in Model.Employees)
            {
                <option value="">@employee.Name</option>
            }
        </select>
    </div>
    <div class="form-group">
        <label>Task</label>
        <select asp-for="Tasklists" name="Tasklists" class="form-control" multiple>
            <option value="">Select Task</option>
            @foreach (var task in Model.Tasklists)
            {
                <option value="">@task.Title</option>
            }
        </select>
    </div>
    <div class="form-group">
        <label asp-for="AssignDate"></label>
        <input asp-for="AssignDate" class="form-control" type="date" />
    </div>
    <div class="form-group">
        <label asp-for="DueDate"></label>
        <input asp-for="DueDate" class="form-control" type="date" />
    </div>
    <div class="form-group">
        <label asp-for="Status"></label>
        <input asp-for="Status" class="form-control" />
    </div>
    <div class="mt-3 mb-3">
        <button type="submit" class="btn btn-primary">Save</button>
        <button type="reset" class="btn btn-warning">Reset</button>
    </div>
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</form>