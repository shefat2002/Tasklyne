@using Tasklyne.Models
@model IEnumerable<Department>
@{
    ViewData["Title"] = "Departments";
}

<div class="container-fluid py-4">
    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h2 class="card-title mb-0 fw-bold">Departments</h2>
            <button type="button" class="btn btn-outline-primary ms-auto" onclick="openSaveModal()">
                <i class="fa fa-plus"></i> Add Department
            </button>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table id="departmentTable" class="table table-striped table-hover" style="width:100%">
                    <thead class="table-dark">
                        <tr>
                            @* <th>ID</th> *@
                            <th>Name</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <!-- Data will be loaded via AJAX -->
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Save/Update Modal -->
<div class="modal fade" id="saveModal" tabindex="-1" aria-labelledby="saveModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="saveModalLabel">Save Department</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="departmentForm">
                    <input type="hidden" id="departmentId" />
                    <div class="mb-3">
                        <label for="departmentName" class="form-label">Department Name</label>
                        <input type="text" class="form-control" id="departmentName" required maxlength="10">
                        <span class="invalid-feedback" ></span>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                <button type="button" class="btn btn-primary" onclick="saveDepartment()">Save</button>
            </div>
        </div>
    </div>
</div>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="deleteModalLabel">Confirm Deletion</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                Are you sure you want to delete this department?
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" id="confirmDeleteBtn">Delete</button>
            </div>
        </div>
    </div>
</div>


@section Scripts {
    <script>
        $(document).ready(function () {
            loadDepartments();
        });

        function loadDepartments() {
            $.ajax({
                url: '@Url.Action("Get", "Department")',
                type: 'GET',
                dataType: 'json',
                success: function (data) {
                    var tableBody = $('#departmentTable tbody');
                    tableBody.empty();
                    $.each(data, function (index, item) {
                        var row = '<tr>' +
                            // '<td>' + item.id + '</td>' +
                            '<td>' + item.name + '</td>' +
                            '<td class="text-center">' +
                            '<button class="btn btn-sm btn-warning me-2" onclick="openSaveModal(' + item.id + ')"><i class="fas fa-edit"></i> Edit</button>' +
                            '<button class="btn btn-sm btn-danger" onclick="openDeleteModal(' + item.id + ')"><i class="fas fa-trash"></i> Delete</button>' +
                            '</td>' +
                            '</tr>';
                        tableBody.append(row);
                    });
                },
                error: function () {
                    alert('Error loading departments.');
                }
            });
        }

        function openSaveModal(id) {
            $('#departmentForm')[0].reset();
            $('#departmentId').val('');
            $('#departmentName').removeClass('is-invalid');

            if (id) {
                // Edit mode
                $('#saveModalLabel').text('Edit Department');
                $.ajax({
                    url: '@Url.Action("GetbyId", "Department")/' + id,
                    type: 'GET',
                    success: function (data) {
                        $('#departmentId').val(data.id);
                        $('#departmentName').val(data.name);
                        $('#saveModal').modal('show');
                    },
                    error: function () {
                        toastr.error('Error fetching department details.');
                    }
                });
            } else {
                // Create mode
                $('#saveModalLabel').text('Add Department');
                $('#saveModal').modal('show');
            }
        }

        function saveDepartment() {
            var departmentName = $('#departmentName').val();
            var nameRegex = /^[a-zA-Z\s]*$/;
            var feedbackSpan = $('#departmentName').next('.invalid-feedback');

            $('#departmentName').removeClass('is-invalid');
            feedbackSpan.hide();

            if (!departmentName) {
                feedbackSpan.text('Department name is required.').show();
                $('#departmentName').addClass('is-invalid');
                return;
            }
            if (departmentName.length > 10) {
                feedbackSpan.text('Department name cannot exceed 10 characters.').show();
                $('#departmentName').addClass('is-invalid');
                return;
            }
            if (!nameRegex.test(departmentName)) {
                feedbackSpan.text('Department name can only contain letters and spaces.').show();
                $('#departmentName').addClass('is-invalid');
                return;
            }
            
            var departmentId = $('#departmentId').val();
            var isUpdate = departmentId !== '';

            var url = isUpdate ? '@Url.Action("Update", "Department")' : '@Url.Action("Save", "Department")';
            var type = isUpdate ? 'POST' : 'POST'; 

            var data = {
                id: departmentId,
                name: departmentName
            };

            $.ajax({
                url: url,
                type: type,
                data: data,
                success: function (response) {
                    if (response.success) {
                        $('#saveModal').modal('hide');
                        loadDepartments();
                        toastr.success(response.message);
                    } else {
                        toastr.error('Error: ' + response.message);
                    }
                },
                error: function () {
                    toastr.error('An unexpected error occurred.');
                }
            });
        }

        function openDeleteModal(id) {
            $('#deleteModal').modal('show');
            $('#confirmDeleteBtn').off('click').on('click', function () {
                deleteDepartment(id);
            });
        }

        function deleteDepartment(id) {
            $.ajax({
                url: '@Url.Action("Delete", "Department")/' + id,
                type: 'POST', // Using POST for delete to be safe
                success: function (response) {
                    if (response.success) {
                        $('#deleteModal').modal('hide');
                        loadDepartments();
                        toastr.success(response.message);
                    } else {
                        toastr.error('Error: ' + response.message);
                    }
                },
                error: function () {
                    toastr.error('An unexpected error occurred while deleting.');
                }
            });
        }
    </script>
}